    <style>
        /* Базовая структура */
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            display: flex;
        }

        /* Боковая панель */
        #sidebar {
            position: absolute;
            width: 250px;
            height: 100vh;
            background: #2f3236;
            padding: 1em;
            transition: transform 0.3s ease;
        }

        /* Контейнер страниц */
        #page-container {
            flex: 1;
            position: relative;
            padding: 15px;
            background: #f5f5f5;
        }

        /* Стили для страниц */
        .page-frame {
            background: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            padding: 15px;
        }

        /* Анимации */
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Медиа-запросы */
        @media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
            }
            
            #page-container {
                padding: 10px;
            }
        }
    </style>
</head>

